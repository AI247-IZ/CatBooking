generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id               String   @id @default(cuid())
  name             String
  phone            String
  email            String
  checkInDate      DateTime
  checkOutDate     DateTime
  numberOfCats     Int
  totalPrice       Float
  paymentType      String   // "deposit" or "full"
  paymentStatus    String   // "pending_payment", "deposit_paid", "fully_paid"
  receiptUrl       String?
  notes            String?
  createdAt        DateTime @default(now())
}
